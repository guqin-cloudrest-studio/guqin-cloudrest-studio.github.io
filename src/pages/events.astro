---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Events">
  <section class="page">
    <h1 class="page-title">Events</h1>

    <div class="section">
      <h2 class="section-title">Upcoming</h2>
      <div class="events-list">
        <div class="event-card">
          <div class="event-date">
            <span class="event-month">Jun</span>
            <span class="event-day">15</span>
          </div>
          <div class="event-details">
            <h3>Summer Solstice Concert</h3>
            <p class="event-location">Serenity Hall, Beijing</p>
            <p class="event-desc">An evening of guqin music celebrating the longest day of the year.</p>
          </div>
        </div>
        <div class="event-card">
          <div class="event-date">
            <span class="event-month">Aug</span>
            <span class="event-day">22</span>
          </div>
          <div class="event-details">
            <h3>Guqin Workshop: Beginners</h3>
            <p class="event-location">CloudRest Studio, Shanghai</p>
            <p class="event-desc">Introduction to guqin playing &mdash; posture, plucking, and the first melody.</p>
          </div>
        </div>
        <div class="event-card">
          <div class="event-date">
            <span class="event-month">Oct</span>
            <span class="event-day">5</span>
          </div>
          <div class="event-details">
            <h3>Autumn Meditation Retreat</h3>
            <p class="event-location">Mountainside Temple, Hangzhou</p>
            <p class="event-desc">A weekend retreat combining guqin music with seated meditation.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="section">
      <h2 class="section-title">Past Events</h2>
      <div class="events-list past">
        <div class="event-card past">
          <div class="event-date">
            <span class="event-month">Mar</span>
            <span class="event-day">12</span>
          </div>
          <div class="event-details">
            <h3>Spring Blossoms Concert</h3>
            <p class="event-location">Grand Theater, Guangzhou</p>
          </div>
        </div>
        <div class="event-card past">
          <div class="event-date">
            <span class="event-month">Jan</span>
            <span class="event-day">8</span>
          </div>
          <div class="event-details">
            <h3>New Year Guqin Gathering</h3>
            <p class="event-location">Cultural Center, Chengdu</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .events-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .event-card {
    display: flex;
    gap: 1.5rem;
    background: #fff;
    border: 1px solid #eee;
    border-radius: 8px;
    padding: 1.5rem;
    transition: transform 0.2s;
  }
  .event-card:hover {
    transform: translateX(4px);
  }
  .event-card.past {
    opacity: 0.6;
  }
  .event-date {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 70px;
  }
  .event-month {
    font-size: 0.8rem;
    text-transform: uppercase;
    color: #8b7355;
    font-weight: 600;
  }
  .event-day {
    font-size: 1.8rem;
    font-weight: 700;
    color: #5a4a3a;
    line-height: 1;
  }
  .event-details h3 {
    margin: 0 0 0.3rem;
    color: #5a4a3a;
    font-size: 1.15rem;
  }
  .event-location {
    margin: 0 0 0.5rem;
    color: #888;
    font-size: 0.9rem;
  }
  .event-desc {
    margin: 0;
    color: #666;
    font-size: 0.9rem;
    line-height: 1.6;
  }
  .past .event-details h3 {
    color: #888;
  }
</style>
