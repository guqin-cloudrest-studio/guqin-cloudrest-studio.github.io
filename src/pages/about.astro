---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About">
  <section class="page">
    <h1 class="page-title">About</h1>

    <div class="bio-section">
      <div class="bio-image">
        <img src="/images/about-portrait.jpg" alt="Musician portrait" />
      </div>
      <div class="bio-text">
        <h2>The Musician</h2>
        <p>
          CloudRest Studio was born from a lifelong passion for the guqin &mdash; an instrument
          that has shaped Chinese culture for over three thousand years. As a dedicated guqin
          player, every note carries the weight of tradition and the stillness of a quiet mind.
        </p>
        <p>
          Trained in classical guqin repertoire and inspired by nature's rhythms, the music
          of CloudRest bridges ancient practice with contemporary expression. Each performance
          is an invitation to slow down, breathe, and find harmony within.
        </p>
        <p>
          Beyond performance, CloudRest Studio is committed to sharing the guqin's beauty
          through workshops, recordings, and collaborations with fellow artists.
        </p>
      </div>
    </div>

    <div class="section">
      <h2 class="section-title">The Guqin</h2>
      <div class="guqin-section">
        <div class="guqin-text">
          <p>
            The guqin (&amp;古琴;) is a plucked seven-string Chinese musical instrument. It has been
            played since ancient times, and has traditionally been favored by scholars and
            literati as an instrument of great subtlety and refinement.
          </p>
          <p>
            In 2008, the guqin was inscribed on UNESCO's Representative List of the
            Intangible Cultural Heritage of Humanity. Its repertoire &mdash; passed down
            through generations &mdash; evokes landscapes, seasons, and philosophical ideas.
          </p>
        </div>
        <img src="/images/about-stage.jpg" alt="Guqin performance" class="guqin-img" />
      </div>
    </div>

    <div class="section">
      <img src="/images/about-banner.jpg" alt="Studio banner" class="banner-img" />
    </div>
  </section>
</BaseLayout>

<style>
  .bio-section {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 3rem;
    align-items: start;
    margin-bottom: 4rem;
  }
  .bio-image img {
    width: 100%;
    border-radius: 8px;
  }
  .bio-text h2 {
    margin-top: 0;
    color: #5a4a3a;
  }
  .bio-text p {
    color: #555;
    line-height: 1.8;
  }
  .guqin-section {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 2rem;
    align-items: center;
  }
  .guqin-text p {
    color: #555;
    line-height: 1.8;
  }
  .guqin-img {
    width: 100%;
    border-radius: 8px;
  }
  .banner-img {
    width: 100%;
    border-radius: 8px;
  }
  @media (max-width: 768px) {
    .bio-section,
    .guqin-section {
      grid-template-columns: 1fr;
    }
  }
</style>
