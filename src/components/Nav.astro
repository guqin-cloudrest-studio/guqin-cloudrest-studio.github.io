---
const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/music', label: 'Music' },
  { href: '/events', label: 'Events' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/videos', label: 'Videos' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];
---

<nav>
  <a href="/" class="logo">CloudRest</a>
  <button class="hamburger" aria-label="Toggle menu" id="hamburger">
    <span></span><span></span><span></span>
  </button>
  <ul id="nav-menu">
    {links.map(link => (
      <li><a href={link.href}>{link.label}</a></li>
    ))}
  </ul>
</nav>

<script>
  document.getElementById('hamburger')?.addEventListener('click', () => {
    document.getElementById('nav-menu')?.classList.toggle('open');
  });
</script>

<style>
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.2rem 2rem;
    background: #fff;
    border-bottom: 1px solid #eee;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .logo {
    font-size: 1.4rem;
    font-weight: 700;
    color: #5a4a3a;
    text-decoration: none;
    letter-spacing: 0.05em;
  }
  ul {
    display: flex;
    gap: 1.8rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  ul a {
    text-decoration: none;
    color: #555;
    font-size: 0.95rem;
    transition: color 0.2s;
  }
  ul a:hover {
    color: #8b7355;
  }
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .hamburger span {
    width: 24px;
    height: 2px;
    background: #333;
    display: block;
  }
  @media (max-width: 768px) {
    ul {
      display: none;
      position: absolute;
      top: 60px;
      left: 0;
      right: 0;
      background: #fff;
      flex-direction: column;
      padding: 1rem 2rem;
      border-bottom: 1px solid #eee;
      gap: 1rem;
    }
    ul.open {
      display: flex;
    }
    .hamburger {
      display: flex;
    }
  }
</style>
