---
import BaseLayout from '../layouts/BaseLayout.astro';

const galleryImages = [
  { src: '/images/gallery-scene-1.jpg', alt: 'Performance scene 1' },
  { src: '/images/gallery-art-1.jpg', alt: 'Artistic piece 1' },
  { src: '/images/gallery-scene-2.jpg', alt: 'Scenery 2' },
  { src: '/images/about-stage.jpg', alt: 'Stage performance' },
  { src: '/images/about-group.jpg', alt: 'Group photo' },
  { src: '/images/banner-decorative.jpg', alt: 'Decorative banner' },
];
---

<BaseLayout title="Gallery">
  <section class="page">
    <h1 class="page-title">Gallery</h1>
    <div class="gallery-grid">
      {galleryImages.map(img => (
        <a href={img.src} class="gallery-item" target="_blank">
          <img src={img.src} alt={img.alt} loading="lazy" />
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }
  .gallery-item {
    display: block;
    border-radius: 6px;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .gallery-item:hover {
    transform: scale(1.02);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
  }
  .gallery-item img {
    width: 100%;
    height: 300px;
    object-fit: cover;
  }
</style>
