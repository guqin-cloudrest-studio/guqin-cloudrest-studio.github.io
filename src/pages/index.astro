---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
  <section class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>CloudRest Studio</h1>
      <p class="hero-subtitle">Guqin &middot; Serenity &middot; Tradition</p>
      <p class="hero-desc">Exploring the timeless beauty of the guqin through music, meditation, and art.</p>
      <div class="hero-links">
        <a href="/music" class="btn">Listen to Music</a>
        <a href="/about" class="btn btn-outline">Learn More</a>
      </div>
    </div>
  </section>

  <section class="page">
    <div class="intro-section">
      <h2>Welcome</h2>
      <p>
        Step into a world of tranquil melodies. CloudRest Studio is a haven for the ancient art of guqin,
        a seven-stringed zither that has accompanied Chinese scholars and poets for millennia.
        Here, tradition meets the present, offering you a moment of peace through music.
      </p>
      <div class="quick-links grid-3">
        <a href="/music" class="card">
          <h3>Music</h3>
          <p>Explore recordings and albums</p>
        </a>
        <a href="/events" class="card">
          <h3>Events</h3>
          <p>Upcoming performances &amp; workshops</p>
        </a>
        <a href="/blog" class="card">
          <h3>Blog</h3>
          <p>Stories, thoughts &amp; updates</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    height: 90vh;
    min-height: 500px;
    background: url('/images/hero-bg.jpg') center center / cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.45);
  }
  .hero-content {
    position: relative;
    text-align: center;
    color: #fff;
    padding: 2rem;
    max-width: 700px;
  }
  .hero-content h1 {
    color: #fff;
    font-size: 3.2rem;
    margin: 0 0 0.5rem;
    letter-spacing: 0.08em;
  }
  .hero-subtitle {
    font-size: 1.2rem;
    opacity: 0.85;
    letter-spacing: 0.15em;
    margin: 0 0 1rem;
    text-transform: uppercase;
  }
  .hero-desc {
    font-size: 1.05rem;
    opacity: 0.8;
    margin: 0 0 2rem;
    line-height: 1.6;
  }
  .hero-links {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-outline {
    background: transparent;
    border: 2px solid #fff;
    color: #fff;
  }
  .btn-outline:hover {
    background: #fff;
    color: #333;
  }
  .intro-section {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }
  .intro-section h2 {
    font-size: 2rem;
    color: #5a4a3a;
    margin-bottom: 1rem;
  }
  .intro-section p {
    font-size: 1.05rem;
    color: #555;
    line-height: 1.8;
    margin-bottom: 3rem;
  }
  .quick-links {
    margin-top: 1rem;
  }
  .card {
    display: block;
    padding: 2rem;
    background: #fff;
    border: 1px solid #eee;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
  }
  .card h3 {
    margin: 0 0 0.5rem;
    color: #5a4a3a;
  }
  .card p {
    margin: 0;
    color: #777;
    font-size: 0.95rem;
  }
  @media (max-width: 768px) {
    .hero { height: 70vh; }
    .hero-content h1 { font-size: 2rem; }
  }
</style>
